# CloudJudge LMS

# Environment
ENVIRONMENT=development
DEBUG=false

# Backend
BACKEND_URL=http://localhost:8000

# Frontend
FRONTEND_URL=http://localhost:5173

# Database
# Local MySQL: mysql+aiomysql://cloudjudge:password@localhost:3306/cloudjudge?charset=utf8mb4
# Supabase PostgreSQL: postgresql+asyncpg://postgres:<password>@<host>:5432/postgres
DATABASE_URL=mysql+aiomysql://cloudjudge:password@localhost:3306/cloudjudge?charset=utf8mb4
MYSQL_ROOT_PASSWORD=password
MYSQL_DATABASE=cloudjudge
MYSQL_USER=cloudjudge
MYSQL_PASSWORD=password

# Security
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# Cloud (GCP)
GCP_PROJECT_ID=your-gcp-project-id
GCP_REGION=asia-southeast1

# Supabase (future storage integration)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=lesson-files
