# CloudJudge LMS Frontend Environment

# API URL (leave empty for proxy)
VITE_API_URL=

# Optional: External API URL for production
# VITE_API_URL=https://api.cloudjudge-lms.com

# Mock Authentication Modea
# Set to 'true' to enable mock authentication without backend
# Demo accounts:
#   admin@cloudjudge.com / admin123
#   instructor@cloudjudge.com / instructor123
#   student@cloudjudge.com / student123
VITE_MOCK_AUTH=true
